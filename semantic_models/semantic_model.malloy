-- TPC-DS Star Schema — Malloy Semantic Model
-- SF=1 | DuckDB | 1998–2003
-- Connection: tpcds (DuckDB, C:/llm/data/DS01.duckdb)

source: date_dim is tpcds.table('date_dim') extend {
  primary_key: d_date_sk
}

source: store is tpcds.table('store') extend {
  primary_key: s_store_sk
}

source: item is tpcds.table('item') extend {
  primary_key: i_item_sk
}

source: customer is tpcds.table('customer') extend {
  primary_key: c_customer_sk
}

source: store_sales is tpcds.table('store_sales') extend {
  join_one: date_dim on ss_sold_date_sk = date_dim.d_date_sk
  join_one: store on ss_store_sk = store.s_store_sk
  join_one: item on ss_item_sk = item.i_item_sk
  join_one: customer on ss_customer_sk = customer.c_customer_sk

  measure: total_sales is sum(ss_sales_price * ss_quantity)
  measure: total_quantity is ss_quantity.sum()
  measure: sales_tickets is count(ss_ticket_number)
}

source: store_returns is tpcds.table('store_returns') extend {
  join_one: date_dim on sr_returned_date_sk = date_dim.d_date_sk
  join_one: store on sr_store_sk = store.s_store_sk
  join_one: item on sr_item_sk = item.i_item_sk
  join_one: customer on sr_customer_sk = customer.c_customer_sk

  measure: total_returns is sr_return_amt.sum()
}

source: transactions is tpcds.sql("""
  SELECT
    ss_store_sk    AS store_sk,
    ss_item_sk     AS item_sk,
    ss_customer_sk AS customer_sk,
    ss_sold_date_sk AS date_sk,
    ss_ticket_number AS ticket_number,
    COALESCE(ss_sales_price * ss_quantity, 0.0) AS sale_amount,
    0.0 AS return_amount,
    COALESCE(ss_quantity, 0) AS quantity
  FROM store_sales
  UNION ALL
  SELECT
    sr_store_sk, sr_item_sk, sr_customer_sk,
    sr_returned_date_sk, sr_ticket_number,
    0.0, COALESCE(sr_return_amt, 0.0),
    0
  FROM store_returns
""") extend {
  join_one: date_dim on date_sk = date_dim.d_date_sk
  join_one: store on store_sk = store.s_store_sk
  join_one: item on item_sk = item.i_item_sk
  join_one: customer on customer_sk = customer.c_customer_sk

  measure: total_sales    is sale_amount.sum()
  measure: total_returns  is return_amount.sum()
  measure: total_quantity is quantity.sum()
  measure: net_sales      is sale_amount.sum() - return_amount.sum()
  measure: return_rate    is (return_amount.sum() / sale_amount.sum()) * 100
  measure: sales_tickets  is count(ticket_number) { where: return_amount = 0 }
}
